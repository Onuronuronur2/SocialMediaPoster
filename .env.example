# ── TikTok ───────────────────────────────────────────────────────────────────
# Dein TikTok-Nutzername OHNE @  (z.B. "maxmuster")
TIKTOK_USERNAME=

# Exportierte TikTok-Browser-Cookies als Base64-String
# Anleitung: Chrome-Extension "Get cookies.txt LOCALLY" → tiktok.com → Export
# Dann im Terminal: base64 -i cookies.txt | tr -d '\n'
TIKTOK_COOKIES_B64=

# ── Meta / Instagram ──────────────────────────────────────────────────────────
# Meta for Developers → App → App ID / App Secret
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Deine Instagram Business/Creator Account ID
INSTAGRAM_USER_ID=

# Instagram Long-Lived Access Token (gültig 60 Tage, wird automatisch refresht)
# Erstellen via: developers.facebook.com/tools/explorer
# Permissions: instagram_basic, instagram_content_publish, pages_read_engagement
INSTAGRAM_ACCESS_TOKEN=

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token mit "gist" Scope
GIST_TOKEN=

# ID des Secret Gist (wird durch setup.py erstellt)
GIST_ID=

# ── Discord (optional – Benachrichtigungen & Alarme) ─────────────────────────
# Discord-Server → Kanal-Einstellungen → Integrationen → Webhooks → Neuer Webhook
DISCORD_WEBHOOK_URL=

# ── Archiv-Backup (optional) ──────────────────────────────────────────────────
# Privates Repo für dauerhafte Video-Backups, z.B. "DeinUser/TikTok-Archiv"
# ARCHIVE_REPO als GitHub-Variable (nicht Secret), ARCHIVE_TOKEN = PAT mit repo-Scope
ARCHIVE_REPO=
ARCHIVE_TOKEN=

# ── Posting-Zeitfenster (optional) ────────────────────────────────────────────
# Nur in diesem Zeitfenster posten (Europe/Berlin), z.B. "17-21".
# Videos außerhalb warten in der Queue. Leer = sofort posten.
# Als GitHub-Variable setzen (Settings → Secrets and variables → Variables)
POSTING_WINDOW=
