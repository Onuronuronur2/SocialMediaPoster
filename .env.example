# ── TikTok Developer App ──────────────────────────────────────────────────────
# developers.tiktok.com → App → App Key / App Secret
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Dein TikTok-Nutzername OHNE @  (z.B. "maxmuster")
TIKTOK_USERNAME=

# Exportierte TikTok-Browser-Cookies als Base64-String
# Anleitung: Chrome-Extension "Get cookies.txt LOCALLY" → tiktok.com → Export
# Dann: base64 -i cookies.txt | tr -d '\n'  → diesen String hier eintragen
TIKTOK_COOKIES_B64=

# ── Meta / Instagram ──────────────────────────────────────────────────────────
# Meta for Developers → App → App ID / App Secret
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Deine Instagram Business/Creator Account ID
# Holen via: GET https://graph.facebook.com/v21.0/me/accounts (mit Page Token)
# Dann: GET /{page-id}?fields=instagram_business_account
INSTAGRAM_USER_ID=

# Instagram Long-Lived Access Token (gültig 60 Tage, wird automatisch refresht)
# Erstellen via Graph API Explorer: graph.facebook.com/graphiql
# Benötigte Permissions: instagram_basic, instagram_content_publish, pages_read_engagement
# Kurzlebigen Token → "Generate Long-Lived Token" im API Explorer
INSTAGRAM_ACCESS_TOKEN=

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token mit "gist" Scope (für State-Speicherung)
# github.com → Settings → Developer Settings → Personal access tokens
GIST_TOKEN=

# ID des Secret Gist (wird durch setup.py automatisch erstellt)
GIST_ID=

# ── Telegram (optional) ───────────────────────────────────────────────────────
# Bot erstellen via @BotFather, dann:
# Chat-ID: Nachricht an Bot schicken, dann GET /getUpdates aufrufen
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
